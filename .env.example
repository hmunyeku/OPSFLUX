# =============================================================================
# OpsFlux — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development                # development | staging | production
SECRET_KEY=CHANGEME_GENERATE_WITH_openssl_rand_hex_32
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_HOSTS=*
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://opsflux:opsflux_dev@postgres:5432/opsflux
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Authentication (JWT) ────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGEME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── SSO (optional) ─────────────────────────────────────────────────────────
OAUTH2_ISSUER_URL=
OAUTH2_CLIENT_ID=opsflux
OAUTH2_CLIENT_SECRET=
OAUTH2_AUDIENCE=opsflux-api

# ─── Storage S3-compatible ───────────────────────────────────────────────────
STORAGE_BACKEND=local                  # local | minio | s3
S3_ENDPOINT=http://minio:9000
S3_BUCKET=opsflux-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
STORAGE_MAX_FILE_SIZE_MB=50

# ─── Email ───────────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@opsflux.io
SMTP_FROM_NAME=OpsFlux
SMTP_USE_TLS=false

# ─── AI / MCP ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ─── Domains ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
WEB_URL=http://localhost:5174
