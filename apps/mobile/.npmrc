# EAS build + local installs must tolerate peer-dep warnings that Expo
# SDK 52 generates (e.g. @react-aria/checkbox pinned to react ^17 vs our
# react 18). These warnings are non-fatal, but NPM v9+ treats some as
# errors under strict mode. Keep legacy-peer-deps on for now; revisit
# when we bump Expo SDK.
legacy-peer-deps=true
