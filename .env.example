# =============================================================================
# OpsFlux — Environment Variables (canonical reference)
# =============================================================================
# Copy this file to `.env` and fill in the values.
#
# Conventions:
#   - All variables are READ at backend startup via pydantic-settings
#     (see app/core/config.py) OR by docker-compose at boot time.
#   - Values flagged "REQUIRED in production" are checked at boot and
#     refuse to start if left at the default.
#   - Generate every CHANGEME with: openssl rand -hex 32
#
# Sections in this file:
#   1. Application core            7. SSO / OAuth2
#   2. PostgreSQL                  8. Storage (local | S3 | MinIO)
#   3. Redis                       9. Email (SMTP)
#  4. JWT (sessions)              10. Encryption (column-level)
#   5. Auth security              11. AI / MCP
#   6. LDAP / AD                  12. Monitoring (Sentry, Prometheus)
#                                 13. Domains
#                                 14. First-run seed (entity + admin)
#                                 15. Internal services (agent worker, MCP)
#                                 16. Deploy automation (Dokploy, optional)
#                                 17. Compose helpers (DOMAIN, BUILD_ID, ...)

# ─── 1. Application core ─────────────────────────────────────────────────────
ENVIRONMENT=production                    # development | staging | production
SECRET_KEY=CHANGEME                       # REQUIRED in prod — openssl rand -hex 32
API_BASE_URL=https://api.opsflux.io
FRONTEND_URL=https://app.opsflux.io
ALLOWED_HOSTS=api.opsflux.io,app.opsflux.io,db.opsflux.io,mcp.opsflux.io,ext.opsflux.io
ALLOWED_ORIGINS=https://app.opsflux.io,https://ext.opsflux.io,https://api.opsflux.io
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Entity-ID,X-Tenant,X-Request-Id,Accept,Accept-Language,X-External-Session,X-Acting-Context
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
DEV_SEED_ON_STARTUP=false                 # dev only: seed demo data on every boot

# ─── 2. PostgreSQL ───────────────────────────────────────────────────────────
# DATABASE_URL is what the backend reads. POSTGRES_* are read by the db image
# AND by /api/admin-tools to label connections in pgAdmin.
DATABASE_URL=postgresql+asyncpg://postgres:CHANGEME@db:5432/opsflux
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME                # REQUIRED — must match DATABASE_URL
POSTGRES_DB=opsflux

# ─── 3. Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SCHEDULER_LEADER_LOCK_KEY=opsflux:scheduler:leader
SCHEDULER_LEADER_TTL_SECONDS=120          # leader heartbeat — bump if scheduler stalls

# ─── 4. JWT (sessions) ───────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGEME                   # REQUIRED in prod — openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480       # 8h
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 5. Auth security (AUP §5.2 + §7-8) ──────────────────────────────────────
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_SPECIAL=true
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_DIGIT=true
AUTH_PASSWORD_REJECT_UPN=true             # reject passwords containing the email
AUTH_PASSWORD_HISTORY_SIZE=5              # 0 disables reuse check
AUTH_PASSWORD_MAX_AGE_DAYS=180            # 0 disables expiration
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MIN=15
AUTH_LOGIN_RATE_LIMIT_PER_IP=10           # max attempts/IP/min
AUTH_LOGIN_RATE_LIMIT_PER_EMAIL=5         # max attempts/email/min
AUTH_CAPTCHA_ENABLED=false
AUTH_CAPTCHA_PROVIDER=turnstile           # turnstile | hcaptcha | recaptcha
AUTH_CAPTCHA_SECRET_KEY=
AUTH_CAPTCHA_SITE_KEY=
AUTH_GEO_BLOCKING_ENABLED=false
AUTH_ALLOWED_COUNTRIES=                   # comma-separated ISO codes; empty = all
AUTH_SUSPICIOUS_LOGIN_NOTIFY=true

# ─── 6. LDAP / Active Directory (optional) ──────────────────────────────────
LDAP_SERVER_URL=                          # ldaps://ad.example.com:636
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_USER_SEARCH_FILTER=(objectClass=person)
LDAP_GROUP_SEARCH_FILTER=(objectClass=group)

# ─── 7. SSO / OAuth2 (optional) ─────────────────────────────────────────────
OAUTH2_ISSUER_URL=                        # e.g. https://login.microsoftonline.com/<tenant>/v2.0
OAUTH2_CLIENT_ID=opsflux
OAUTH2_CLIENT_SECRET=
OAUTH2_AUDIENCE=opsflux-api

# ─── 8. Storage (local | S3 | MinIO) ────────────────────────────────────────
STORAGE_BACKEND=local                     # local | minio | s3
S3_ENDPOINT=http://minio:9000             # only when STORAGE_BACKEND=minio|s3
S3_BUCKET=opsflux-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
STORAGE_MAX_FILE_SIZE_MB=50

# ─── 9. Email (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=mail.opsflux.io
SMTP_PORT=465                             # 465 (SSL) | 587 (STARTTLS) | 1025 (mailhog dev)
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@opsflux.io
SMTP_FROM_NAME=OpsFlux
SMTP_USE_TLS=true                         # false for dev mailhog

# ─── 10. Encryption (column-level) ──────────────────────────────────────────
# Used to encrypt sensitive columns (legal IDs, secrets, MFA seeds, ...). MUST
# be the same value across the backend AND the agent-worker pool. Generate
# with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGEME                   # REQUIRED — Fernet key (44-char base64)

# ─── 11. AI / MCP ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # optional — required for Claude-powered features
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434    # optional — local LLM fallback
OLLAMA_DEFAULT_MODEL=llama3
MCP_GATEWAY_TOKEN=                        # auth token required by mcp.<domain> gateway

# ─── 12. Monitoring ─────────────────────────────────────────────────────────
SENTRY_DSN=                               # https://<key>@<org>.ingest.sentry.io/<id>
PROMETHEUS_ENABLED=false

# ─── 13. Domains ────────────────────────────────────────────────────────────
# These should match what Traefik serves. Used by the backend to compute
# CORS origins and to build absolute URLs in emails/notifications.
APP_URL=https://app.opsflux.io
API_URL=https://api.opsflux.io
WEB_URL=https://www.opsflux.io

# ─── 14. First-run seed (entity + admin) ────────────────────────────────────
# Read by app/services/core/seed_service.py the first time the backend boots
# against an empty DB. Once the entity + admin exist, these are ignored.
FIRST_ENTITY_CODE=CM
FIRST_ENTITY_NAME=ACME Energy
FIRST_ENTITY_COUNTRY=CM                   # ISO 3166-1 alpha-2
FIRST_ENTITY_TIMEZONE=Africa/Douala       # IANA tz
FIRST_ENTITY_CURRENCY=XAF                 # ISO 4217
FIRST_SUPERUSER=admin@opsflux.io
FIRST_SUPERUSER_PASSWORD=ChangeMeOnFirstLogin!  # CHANGE BEFORE PRODUCTION

# ─── 15. Internal services (agent worker pool — optional) ───────────────────
# The autonomous maintenance agent runs in its own compose project at
# `agent-worker/docker-compose.yml`. Only set these if you deploy that
# project. ENCRYPTION_KEY must match section 10.
OPSFLUX_INTERNAL_TOKEN=                   # service-to-service auth between worker and API
AGENT_IMAGE=ghcr.io/hmunyeku/opsflux-agent-runner:latest
AGENT_LOG_ROOT=/var/log/opsflux-agent
AGENT_SCHEDULER_TRIGGER_INTERVAL_S=300
AGENT_SCHEDULER_DIGEST_INTERVAL_S=900
TICKET_HOUSEKEEPING_INTERVAL_S=3600
AUTO_CLOSE_RESOLVED_AFTER_DAYS=7
AUTO_CLOSE_WARN_BEFORE_DAYS=6
WEEKLY_DIGEST_INTERVAL_S=3600
ORPHAN_RESCUE_INTERVAL_S=300
ORPHAN_STALE_AFTER_MINUTES=45

# ─── 16. Deploy automation (Dokploy — optional) ─────────────────────────────
# Only used by helper scripts (e.g. scripts/deploy-vps.sh). Skip if you run
# vanilla Docker Compose on your VPS.
API_DOKPLOY=
API_DOKPLOY_URL=http://127.0.0.1:3000/api
DOKPLOY_COMPOSE_ID=

# ─── 17. Compose helpers ────────────────────────────────────────────────────
# DOMAIN templates every Host() rule in docker-compose.yml. STACK_NAME
# templates every Traefik router/service/middleware name so multiple
# OpsFlux instances can coexist behind the same Traefik (prod + staging,
# blue/green, etc.). BUILD_ID is a cache-buster for the frontend Vite
# build — bump it when env-baked-in vars change.
DOMAIN=opsflux.io
STACK_NAME=opsflux                        # opsflux-staging | opsflux-blue | opsflux-test
BUILD_ID=1
UID=1000                                  # uvicorn user — avoids root in container
GID=1000
