{
  "root": true,
  "env": {
    "browser": true,
    "es2020": true,
    "node": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["react-hooks", "@typescript-eslint"],
  "ignorePatterns": [
    "dist",
    "build",
    "node_modules",
    "coverage",
    "**/*.config.js",
    "**/*.config.ts",
    "tailwind.config.*",
    "vite.config.*",
    "vitest.config.*",
    "postcss.config.*",
    ".eslintrc.json"
  ],
  "rules": {
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "off"
  }
}
